# MySQL — Prisma exige URL no formato mysql:// (não use jdbc:).
# Crie o banco antes, por exemplo:
#   CREATE DATABASE agro_sara CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DATABASE_URL="mysql://usuario:senha@127.0.0.1:3306/agro_sara"

# Opcional: arquivo SQLite antigo para copiar dados com `npm run migrate:sqlite-to-mysql`
# SQLITE_DATABASE_PATH=./dev.db

PORT=4000
HOST=127.0.0.1
JWT_SECRET=troque-este-segredo-min-16-chars
FRONTEND_ORIGIN=http://localhost:8080
