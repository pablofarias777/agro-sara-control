generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UnidadePadrao {
  kg
  saco
  unidade
  caixa
}

enum CategoriaDespesa {
  sementes
  adubo
  defensivo
  combustivel
  mao_de_obra
  manutencao
  outros
}

enum CentroCustoDespesa {
  plantio
  irrigacao
  mao_de_obra
  transporte
  insumos
  manutencao
}

enum CanalVenda {
  feira
  atravessador
  cooperativa
  outros
}

enum CategoriaInsumo {
  sementes
  fertilizantes
  defensivos
  combustivel
  ferramentas
  embalagens
  outros
}

enum UnidadeInsumo {
  kg
  L
  ml
  unidade
  saco
  tonelada
  ha
}

enum EscopoMeta {
  cultura
  safra
}

enum TipoEtapaSafra {
  plantio
  adubacao
  irrigacao
  aplicacao
  colheita
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  nome         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  propriedades Propriedade[]
  culturas     Cultura[]
  safras       Safra[]
  despesas     Despesa[]
  vendas       Venda[]
  insumos      Insumo[]
  metas        Meta[]
  etapasSafra  EtapaCalendarioSafra[]
}

model Propriedade {
  id              String   @id
  userId          String
  nomePropriedade String
  nomeProdutor    String
  criadoEm        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  culturas  Cultura[]
  despesas  Despesa[]

  @@index([userId])
}

model Cultura {
  id             String        @id
  userId         String
  propriedadeId  String
  nome           String
  unidadePadrao  UnidadePadrao
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  propriedade Propriedade @relation(fields: [propriedadeId], references: [id], onDelete: Cascade)
  safras      Safra[]
  vendas      Venda[]

  @@index([userId])
  @@index([propriedadeId])
}

model Safra {
  id          String   @id
  userId      String
  culturaId   String
  dataInicio  String
  dataFim     String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cultura Cultura                @relation(fields: [culturaId], references: [id], onDelete: Restrict)
  etapas  EtapaCalendarioSafra[]

  @@index([userId])
  @@index([userId, culturaId])
}

model Despesa {
  id             String               @id
  userId         String
  propriedadeId  String
  data           String
  categoria      CategoriaDespesa
  centroCusto    CentroCustoDespesa?
  descricao      String
  valor          Float
  culturaId      String?
  safraId        String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  propriedade Propriedade @relation(fields: [propriedadeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, data])
  @@index([propriedadeId])
}

model Venda {
  id         String     @id
  userId     String
  data       String
  culturaId  String
  quantidade Float
  unidade    String
  valorTotal Float
  canal      CanalVenda
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cultura Cultura @relation(fields: [culturaId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([userId, data])
  @@index([userId, culturaId])
}

model Insumo {
  id                   String          @id
  userId               String
  nome                 String
  categoria            CategoriaInsumo
  unidade              UnidadeInsumo
  quantidadeAtual      Float
  alertaEstoqueBaixo   Float
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Meta {
  id                     String      @id
  userId                 String
  escopo                 EscopoMeta
  culturaId              String?
  safraId                String?
  metaFaturamento        Float?
  limiteGasto            Float?
  metaQuantidadeVendida  Float?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EtapaCalendarioSafra {
  id           String         @id
  userId       String
  safraId      String
  tipo         TipoEtapaSafra
  dataPrevista String
  concluida    Boolean        @default(false)
  concluidaEm  String?
  observacao   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  safra Safra @relation(fields: [safraId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([safraId])
}
